# Chatbot Service Environment Variables

# 서버 디버그 모드 (로깅 레벨 변경)
DEBUG=true

# 포트 번호 (기본: 8300)
PORT=8300

# 모델 경로 (HuggingFace 경로)
BASE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
ADAPTER_PATH=models/Qwen2.5-7B/7B-LoRA
CHROMA_DB_DIR=models/chroma_db
EMBEDDING_MODEL_ID=jhgan/ko-sroberta-multitask
EMBEDDING_NORMALIZE=true

# RAG 검색/리랭크 파라미터
RAG_RETRIEVAL_K=5
RAG_FINAL_TOP_K=3
RAG_RERANK_ENABLED=true
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3

# 생성 파라미터
GEN_TEMPERATURE=0.1
GEN_TOP_P=0.9
GEN_MAX_NEW_TOKENS=384
GEN_REPETITION_PENALTY=1.08

# HuggingFace 인증 토큰
HUGGING_FACE_HUB_TOKEN=

# 챗봇 자산 자동 업데이트 옵션
CHECK_MODEL_UPDATE_ON_START=true
FORCE_REFRESH_MODELS=false
MODEL_REVISION_FILE=models/.vet_chat_revision
MODEL_UPDATE_CHECK_INTERVAL_SECONDS=86400
